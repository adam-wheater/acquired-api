{
  "info": {
    "name": "Acquired API",
    "description": "Internal proxy API for Acquired.com payment gateway",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Customers",
      "item": [
        {
          "name": "Create Customer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Company-Id", "value": "{{company_id}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reference\": \"CUST-{{$randomInt}}\",\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"billing\": {\n    \"email\": \"john.doe@example.com\",\n    \"address\": {\n      \"line_1\": \"1 High Street\",\n      \"city\": \"London\",\n      \"postcode\": \"SW1A 1AA\",\n      \"country_code\": \"GB\"\n    }\n  }\n}"
            },
            "url": "{{base_url}}/api/customers"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var json = pm.response.json();",
                  "  pm.environment.set('customer_id', json.customer_id);",
                  "  pm.test('Customer created', function() {",
                  "    pm.expect(json.customer_id).to.be.a('string');",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Customer",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Company-Id", "value": "{{company_id}}" }
            ],
            "url": "{{base_url}}/api/customers/{{customer_id}}"
          }
        },
        {
          "name": "List Customers",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Company-Id", "value": "{{company_id}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/customers?offset=0&limit=25",
              "host": ["{{base_url}}"],
              "path": ["api", "customers"],
              "query": [
                { "key": "offset", "value": "0" },
                { "key": "limit", "value": "25" }
              ]
            }
          }
        },
        {
          "name": "Update Customer",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "X-Company-Id", "value": "{{company_id}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Jane\",\n  \"last_name\": \"Smith\"\n}"
            },
            "url": "{{base_url}}/api/customers/{{customer_id}}"
          }
        }
      ]
    },
