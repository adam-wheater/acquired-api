    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Payment (Card)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Company-Id", "value": "{{company_id}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transaction\": {\n    \"order_id\": \"ORD-{{$randomInt}}\",\n    \"amount\": 10.00,\n    \"currency\": \"gbp\",\n    \"capture\": true\n  },\n  \"payment\": {\n    \"card\": {\n      \"holder_name\": \"John Doe\",\n      \"number\": \"4000000000001000\",\n      \"expiry_month\": 12,\n      \"expiry_year\": 2028,\n      \"cvv\": \"123\"\n    },\n    \"create_card\": true\n  },\n  \"customer\": {\n    \"customer_id\": \"{{customer_id}}\"\n  }\n}"
            },
            "url": "{{base_url}}/api/payments"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var json = pm.response.json();",
                  "  pm.environment.set('transaction_id', json.transaction_id);",
                  "  if (json.card_id) pm.environment.set('card_id', json.card_id);",
                  "  pm.test('Payment created', function() {",
                  "    pm.expect(json.status).to.equal('success');",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Payment (Stored Card)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Company-Id", "value": "{{company_id}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transaction\": {\n    \"order_id\": \"ORD-{{$randomInt}}\",\n    \"amount\": 25.50,\n    \"currency\": \"gbp\",\n    \"capture\": true\n  },\n  \"payment\": {\n    \"card_id\": \"{{card_id}}\"\n  },\n  \"customer\": {\n    \"customer_id\": \"{{customer_id}}\"\n  }\n}"
            },
            "url": "{{base_url}}/api/payments"
          }
        },
        {
          "name": "Create Payment (Auth Only)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Company-Id", "value": "{{company_id}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transaction\": {\n    \"order_id\": \"ORD-{{$randomInt}}\",\n    \"amount\": 50.00,\n    \"currency\": \"gbp\",\n    \"capture\": false\n  },\n  \"payment\": {\n    \"card\": {\n      \"holder_name\": \"John Doe\",\n      \"number\": \"4000000000001000\",\n      \"expiry_month\": 12,\n      \"expiry_year\": 2028,\n      \"cvv\": \"123\"\n    }\n  }\n}"
            },
            "url": "{{base_url}}/api/payments"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var json = pm.response.json();",
                  "  pm.environment.set('auth_transaction_id', json.transaction_id);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
